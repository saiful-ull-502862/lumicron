---
// src/pages/albums/index.astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import AlbumCard from '../../components/AlbumCard.astro';
import { getAlbums } from '../../utils/content';

const albums = await getAlbums();
---

<BaseLayout title="Albums">
  <div class="pt-32 pb-24 px-6 md:px-12 max-w-7xl mx-auto min-h-screen">
    
    <div class="flex items-end justify-between mb-16 border-b border-[var(--border-color)] pb-8" data-aos="fade-right">
      <div>
        <h1 class="text-4xl md:text-6xl font-serif italic text-[var(--color-brand-primary)] mb-4">Albums</h1>
        <p class="text-[var(--text-muted)] tracking-wide max-w-xl">
          Curated collections from various shoots and road trips. Each album tells a unique story through a series of photographs.
        </p>
      </div>
      <div class="hidden md:block text-[var(--color-brand-primary)] text-5xl font-serif italic opacity-30">
        {albums.length}
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
      {albums.map((album) => (
        <AlbumCard album={album} />
      ))}
    </div>
    
  </div>
</BaseLayout>
