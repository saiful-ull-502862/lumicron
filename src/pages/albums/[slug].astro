---
// src/pages/albums/[slug].astro
import BaseLayout from '../../layouts/BaseLayout.astro';
import Lightbox from '../../components/Lightbox.astro';
import { getAlbums, getGlobalAlbumImage } from '../../utils/content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const albums = await getAlbums();
  return albums.map(album => ({
    params: { slug: album.slug },
    props: { album },
  }));
}

const { album } = Astro.props;
const coverImg = await getGlobalAlbumImage(album.slug, album.cover);

// Load all image data for the gallery
const photosData = await Promise.all(album.photos.map(async (photo) => {
  const imgData = await getGlobalAlbumImage(album.slug, photo.file);
  return { ...photo, imgData };
}));
---

<BaseLayout title={album.title} description={album.description} image={coverImg?.src}>
  <!-- Album Hero -->
  <div class="relative h-[60vh] md:h-[80vh] w-full mt-20 md:mt-0 pt-20 flex items-end pb-12 px-6 md:px-12">
    <div class="absolute inset-0 z-0">
      {coverImg && (
        <Image 
          src={coverImg}
          alt={album.title}
          class="w-full h-full object-cover filter brightness-50 dark:brightness-40"
        />
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-[var(--bg-color)] via-transparent to-transparent opacity-100"></div>
    </div>
    
    <div class="relative z-10 max-w-4xl" data-aos="fade-up">
      <div class="flex items-center gap-4 mb-4 text-[var(--color-brand-accent)] text-sm uppercase tracking-[0.2em] font-medium">
        <span>{album.categories[0]}</span>
        <span class="w-1 h-1 rounded-full bg-current"></span>
        <span>{album.date}</span>
      </div>
      
      <h1 class="text-5xl md:text-7xl font-serif italic text-white mb-6 leading-tight">
        {album.title}
      </h1>
      
      <div class="flex items-center gap-2 text-[var(--text-color)] opacity-80 font-light tracking-wide">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        {album.location}
      </div>
    </div>
  </div>

  <!-- Description -->
  <div class="max-w-3xl mx-auto px-6 py-16 text-center" data-aos="fade-up">
    <p class="text-lg md:text-xl text-[var(--text-color)] font-light leading-relaxed">
      {album.description}
    </p>
    <div class="w-24 h-px bg-[var(--border-color)] mx-auto mt-12"></div>
  </div>

  <!-- Gallery Grid -->
  <div class="max-w-[1600px] mx-auto px-6 md:px-12 pb-24">
    <div id="pswp-gallery" class="columns-1 sm:columns-2 lg:columns-3 xl:columns-4 gap-6 space-y-6">
      {photosData.map((photo, index) => (
        photo.imgData && (
          <div 
            class="gallery-item break-inside-avoid mb-6 relative group overflow-hidden bg-[var(--bg-secondary)]"
            data-aos="fade-up"
            data-aos-delay={index % 6 * 100}
          >
            <a 
              href={photo.imgData.src} 
              data-pswp-width={photo.imgData.width} 
              data-pswp-height={photo.imgData.height} 
              class="pswp-item block w-full hover-target cursor-zoom-in"
              target="_blank"
            >
              <Image 
                src={photo.imgData} 
                alt={photo.caption}
                width={800}
                class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105"
                loading={index < 4 ? "eager" : "lazy"}
              />
              
              <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
                <p class="text-white text-sm font-light w-full truncate">{photo.caption}</p>
              </div>
            </a>
          </div>
        )
      ))}
    </div>
  </div>

  <Lightbox />
</BaseLayout>
