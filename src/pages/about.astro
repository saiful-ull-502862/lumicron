---
// src/pages/about.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About">
  <div class="pt-32 pb-24 px-6 md:px-12 max-w-5xl mx-auto min-h-screen">
    
    <div class="flex flex-col md:flex-row gap-16 items-center mb-32" data-aos="fade-up">
      <div class="w-full md:w-1/2">
        <div class="aspect-square bg-[var(--bg-secondary)] relative overflow-hidden group">
          <!-- Placeholder for portrait or just use a generic background pattern -->
          <div class="absolute inset-0 bg-gradient-to-br from-[var(--color-brand-primary)]/20 to-transparent"></div>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-[var(--text-muted)] font-serif italic text-2xl tracking-widest opacity-50">Portrait</span>
          </div>
          
          <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-[var(--bg-color)] to-transparent opacity-80"></div>
          
          <!-- Geometric border element -->
          <div class="absolute top-8 left-8 bottom-8 right-8 border border-[var(--color-brand-accent)]/30 scale-105 group-hover:scale-100 transition-transform duration-700 pointer-events-none"></div>
        </div>
      </div>
      
      <div class="w-full md:w-1/2">
        <h1 class="text-4xl md:text-5xl font-serif italic text-[var(--color-brand-primary)] mb-6">About Me</h1>
        <p class="text-xl text-[var(--color-brand-accent)] font-light tracking-wide mb-6 uppercase">
          The Eye Behind the Lens
        </p>

        <div class="space-y-4 text-[var(--text-muted)] font-light leading-relaxed">
          <p>
            I'm Saiful — a photographer based in Bangladesh with a quiet obsession for light, shadow, and the moments most people forget to notice. I shoot portraits, events, cultural gatherings, and everything in between.
          </p>
          <p>
            Moody tones, deep contrasts, and honest frames — that's what I chase. No posing scripts, no forced smiles. Just the real thing.
          </p>
        </div>
        
        <div class="mt-10 pt-10 border-t border-[var(--border-color)]">
          <h3 class="text-sm uppercase tracking-[0.2em] font-medium text-[var(--text-color)] mb-4">Current Gear</h3>
          <ul class="space-y-2 text-[var(--text-muted)] font-mono text-sm">
            <li class="flex justify-between border-b border-[var(--border-color)]/50 pb-2"><span>Camera Body</span> <span>Sony A7IV</span></li>
            <li class="flex justify-between border-b border-[var(--border-color)]/50 pb-2"><span>Primary Lens</span> <span>24-70mm f/2.8 GM</span></li>
            <li class="flex justify-between border-b border-[var(--border-color)]/50 pb-2"><span>Portrait Lens</span> <span>85mm f/1.4 GM</span></li>
            <li class="flex justify-between pb-2"><span>Flash</span> <span>Godox V1</span></li>
          </ul>
        </div>
      </div>
    </div>

  </div>
</BaseLayout>
