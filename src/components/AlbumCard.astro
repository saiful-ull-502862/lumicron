---
// src/components/AlbumCard.astro
import { Image } from 'astro:assets';
import type { Album } from '../utils/content';
import { getGlobalAlbumImage } from '../utils/content';

interface Props {
  album: Album;
}

const { album } = Astro.props;
const coverImg = await getGlobalAlbumImage(album.slug, album.cover);
---

<a href={`/lumicron/albums/${album.slug}`} class="group block relative overflow-hidden aspect-[3/4] hover-target bg-[var(--bg-secondary)]" data-aos="fade-up">
  {coverImg ? (
    <Image 
      src={coverImg} 
      alt={album.title} 
      width={800}
      class="w-full h-full object-cover filter brightness-75 transition-all duration-700 ease-out group-hover:scale-110 group-hover:brightness-50"
    />
  ) : (
    <div class="flex items-center justify-center h-full text-[var(--text-muted)]">No Cover</div>
  )}

  <div class="absolute inset-0 border border-white/0 group-hover:border-white/20 transition-colors duration-500 m-4"></div>
  
  <div class="absolute bottom-0 left-0 w-full p-8 flex flex-col justify-end translate-y-4 group-hover:translate-y-0 opacity-80 group-hover:opacity-100 transition-all duration-500">
    <div class="flex items-center justify-between mb-2">
      <span class="text-[var(--color-brand-accent)] text-xs uppercase tracking-widest font-semibold">{album.categories[0]}</span>
      <span class="text-white/70 text-xs tracking-wider">{album.photos.length} Photos</span>
    </div>
    
    <h3 class="text-white text-3xl font-serif italic mb-1">{album.title}</h3>
    
    <div class="flex items-center text-white/60 text-sm mt-3 gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
      </svg>
      {album.location}
    </div>
  </div>
</a>
