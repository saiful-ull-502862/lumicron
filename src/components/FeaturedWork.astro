---
// src/components/FeaturedWork.astro
import { getFeaturedImages, getGlobalAlbumImage } from '../utils/content';
import { Image } from 'astro:assets';

const featuredImages = await getFeaturedImages();

// Fetch unresolved images and resolve the actual astro img object
const resolvedImages = await Promise.all(featuredImages.map(async (f) => {
  const imgModule = await getGlobalAlbumImage(f.albumSlug, f.file);
  return {
    ...f,
    imgData: imgModule
  };
}));
---

<section class="py-24 px-6 md:px-12 max-w-7xl mx-auto">
  <div class="mb-16 text-center" data-aos="fade-up">
    <h2 class="text-3xl md:text-5xl font-serif italic text-[var(--color-brand-primary)] mb-4">Featured Collections</h2>
    <div class="w-16 h-px bg-[var(--color-brand-accent)] mx-auto"></div>
  </div>

  <div class="gsap-gallery grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {resolvedImages.map((item, i) => (
      <a href={`/lumicron/albums/${item.albumSlug}`} 
         class="gsap-reveal group block relative overflow-hidden aspect-[4/5] bg-[var(--bg-secondary)]"
         data-tilt 
         data-tilt-max="5" 
         data-tilt-speed="400" 
         data-tilt-perspective="1000"
      >
        {item.imgData ? (
           <Image
            src={item.imgData}
            alt={item.title}
            width={800}
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
          />
        ) : (
          <div class="flex items-center justify-center h-full text-[var(--text-muted)]">Image missing</div>
        )}
        
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        
        <div class="absolute bottom-0 left-0 w-full p-8 translate-y-4 group-hover:translate-y-0 opacity-0 group-hover:opacity-100 transition-all duration-500">
          <p class="text-[var(--color-brand-accent)] text-xs uppercase tracking-widest mb-2 font-medium">{item.category}</p>
          <h3 class="text-white text-2xl font-serif italic">{item.title}</h3>
        </div>
      </a>
    ))}
  </div>
  
  <div class="mt-16 text-center" data-aos="fade-up">
    <a href="/lumicron/portfolio" class="hover-target inline-flex items-center gap-2 text-[var(--text-muted)] hover:text-[var(--color-brand-primary)] transition-colors uppercase tracking-widest text-sm pb-1 border-b border-transparent hover:border-[var(--color-brand-primary)]">
      View All Work
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
      </svg>
    </a>
  </div>
</section>

<script>
  import VanillaTilt from 'vanilla-tilt';
  
  function initTilt() {
    const elements = document.querySelectorAll('[data-tilt]');
    if (elements.length > 0 && !window.matchMedia('(pointer: coarse)').matches) {
      VanillaTilt.init(Array.from(elements) as HTMLElement[]);
    }
  }

  document.addEventListener('DOMContentLoaded', initTilt);
  document.addEventListener('astro:page-load', initTilt);
</script>
