---
// src/components/Footer.astro
import { getSiteConfig } from '../utils/content';
const siteConfig = await getSiteConfig();
const year = new Date().getFullYear();
---

<footer class="mt-20 py-12 border-t border-[var(--border-color)] text-center px-6">
  <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-8">
    <div class="flex items-center gap-3">
      <img src="/lumicron/logo/lumicron-icon.svg" alt="Lumicron Logo" class="w-7 h-7" />
      <span class="text-lg tracking-[0.05em]">
        <span class="text-[var(--text-color)] font-serif italic pr-0.5 font-bold">Lumi</span><span class="innovative-gradient-text font-sans uppercase font-black">cron</span>
      </span>
    </div>
    
    <div class="text-[var(--text-muted)] text-xs tracking-widest uppercase">
      &copy; {year} {siteConfig.author} &middot; All rights reserved
    </div>
    
    <div class="flex space-x-6 text-[var(--text-color)]">
      {Object.entries(siteConfig.socialLinks).map(([platform, url]) => (
        url && (
          <a href={url as string} target="_blank" rel="noopener noreferrer" class="hover-target hover:text-[var(--color-brand-accent)] transition-colors capitalize text-xs tracking-[0.2em] uppercase">
            {platform}
          </a>
        )
      ))}
    </div>
  </div>
</footer>
