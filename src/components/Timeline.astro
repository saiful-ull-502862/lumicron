---
// src/components/Timeline.astro
const milestones = [
  { year: "2018", title: "First Camera", desc: "Bought my first DSLR and started capturing candid moments of the people around me." },
  { year: "2020", title: "Event Coverage", desc: "Began photographing local events, celebrations, and cultural gatherings across the community." },
  { year: "2023", title: "Published Work", desc: "Featured in several regional photography magazines and digital publications." },
  { year: "Present", title: "Full-Time Pursuit", desc: "Dedicated fully to photographing people, their stories, and the events that bring them together." }
];
---

<div class="relative py-12">
  <div class="hidden md:block absolute left-1/2 transform -translate-x-1/2 h-full w-px bg-[var(--border-color)]"></div>
  
  <div class="space-y-16">
    {milestones.map((item, index) => (
      <div 
        class={`relative flex flex-col md:flex-row items-center justify-between group ${index % 2 === 0 ? 'md:flex-row-reverse' : ''}`}
        data-aos={index % 2 === 0 ? 'fade-left' : 'fade-right'}
      >
        <div class="hidden md:block md:w-5/12"></div>
        
        <div class="absolute left-0 md:left-1/2 transform md:-translate-x-1/2 w-4 h-4 rounded-full bg-[var(--bg-color)] border-2 border-[var(--color-brand-primary)] group-hover:bg-[var(--color-brand-accent)] group-hover:border-[var(--color-brand-accent)] transition-colors duration-300 z-10 mt-1 md:mt-0"></div>
        
        <div class="ml-10 md:ml-0 md:w-5/12 bg-[var(--bg-secondary)] p-8 border hover:border-[var(--color-brand-primary)] transition-colors duration-300 relative border-transparent">
          <span class="text-[var(--color-brand-accent)] text-4xl font-serif italic mb-2 block">{item.year}</span>
          <h4 class="text-xl font-bold tracking-wide mb-3">{item.title}</h4>
          <p class="text-[var(--text-muted)] font-light leading-relaxed">{item.desc}</p>
        </div>
      </div>
    ))}
  </div>
</div>
