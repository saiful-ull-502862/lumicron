---
import '../styles/global.css';
import { getSiteConfig } from '../utils/content';
import CustomCursor from '../components/CustomCursor.astro';
import LoadingScreen from '../components/LoadingScreen.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

const siteConfig = await getSiteConfig();

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  canonicalUrl?: string;
}

const {
  title = siteConfig.siteName,
  description = siteConfig.tagline,
  image = siteConfig.logo,
  type = 'website',
  canonicalUrl = Astro.url.href
} = Astro.props;

const pageTitle = title === siteConfig.siteName ? title : `${title} | ${siteConfig.siteName}`;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/logo/lumicron-icon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.site)} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={pageTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.site)} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Inline script to apply dark mode to avoid FOUC -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'dark'; // Defaulting to dark as requested
      })();
    
      if (theme === 'light') {
        document.documentElement.classList.remove('dark');
      } else {
        document.documentElement.classList.add('dark');
      }
      window.localStorage.setItem('theme', theme);
    </script>
  </head>
  <body class="flex flex-col min-h-screen">
    <LoadingScreen />
    <CustomCursor />
    <Navbar />
    
    <main class="flex-grow">
      <slot />
    </main>
    
    <Footer />
    
    <script src="../scripts/cursor.ts"></script>
    <script src="../scripts/theme.ts"></script>
    <script src="../scripts/animations.ts"></script>
  </body>
</html>
